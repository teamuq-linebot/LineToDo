{
  "name": "line-cua-win",
  "version": "0.1.0",
  "description": "Windows LINE Desktop MCP server: background chat-history reads from the local encrypted DB (key recovered from LINE.exe memory), plus UI-driven sends.",
  "license": "MIT",
  "type": "module",
  "bin": { "line-cua-win": "./dist/server.js" },
  "main": "./dist/server.js",
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-py.mjs",
    "dev": "tsx src/server.ts",
    "smoke": "node scripts/smoke.mjs"
  },
  "keywords": ["mcp", "line", "windows", "sqlite", "wxsqlite3", "model-context-protocol"],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
